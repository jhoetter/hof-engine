# Base image for agent terminal skills (extend in apps; copy generated skills/ to /usr/local/bin).
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash ca-certificates curl jq \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    httpx openpyxl pandas pdfplumber plotly python-pptx requests weasyprint matplotlib

RUN useradd --create-home --shell /bin/bash sandbox

# Same UX as host `hof fn` — list/describe/call allowlisted skills (see HOF_AGENT_SKILLS_CATALOG at runtime).
COPY hof/agent/sandbox/hof_cli.sh /usr/local/bin/hof
RUN chmod +x /usr/local/bin/hof

# Ergonomic SQL Lab entrypoints (build JSON via jq; no invented --sql/--token flags on `hof fn`).
COPY hof/agent/sandbox/sql-lab-query /usr/local/bin/sql-lab-query
COPY hof/agent/sandbox/sql-lab-exec /usr/local/bin/sql-lab-exec
RUN chmod +x /usr/local/bin/sql-lab-query /usr/local/bin/sql-lab-exec

USER sandbox
WORKDIR /workspace

CMD ["sleep", "infinity"]
