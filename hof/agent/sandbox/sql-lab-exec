#!/usr/bin/env bash
# Spreadsheet-app: call sql_lab_execute with read-only SQL (no manual JSON).
# Requires API_BASE_URL, API_TOKEN (sandbox injects both for HTTP auth to /hof fn). Uses /usr/local/bin/hof.
#
# Usage:
#   sql-lab-exec [--limit N] 'SELECT ...'
#   echo 'SELECT ...' | sql-lab-exec [--limit N]
set -euo pipefail

usage() {
  echo "usage: sql-lab-exec [--limit N] <sql-on-one-line>   OR   echo SQL | sql-lab-exec [--limit N]" >&2
  exit 2
}

LIMIT=500
if [[ "${1:-}" == "--limit" ]]; then
  [[ -n "${2:-}" ]] || usage
  LIMIT="$2"
  shift 2
fi

if [[ $# -eq 0 ]]; then
  if [[ -t 0 ]]; then
    usage
  fi
  SQL=$(cat)
elif [[ $# -eq 1 ]]; then
  SQL="$1"
else
  SQL="$*"
fi

[[ -n "${SQL// }" ]] || usage

: "${API_BASE_URL:?set API_BASE_URL}"
: "${API_TOKEN:?set API_TOKEN}"

BODY=$(jq -n --arg s "$SQL" --argjson l "$LIMIT" '{sql:$s, limit:$l}')

exec /usr/local/bin/hof fn sql_lab_execute "$BODY"
